<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:GuacClient"
        x:Class="GuacClient.ChooseServerDialog"
        Width="760" Height="460"
        MinWidth="700" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Title="Choose server">
  <Grid Margin="16"
        RowDefinitions="*,Auto"
        ColumnDefinitions="*,Auto"
        RowSpacing="12"
        ColumnSpacing="12">
    <ListBox x:Name="ProfilesListBox"
             Grid.Row="0" Grid.Column="0"
             BorderThickness="1">
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="local:ProfileListItem">
          <Border Background="{Binding BackgroundBrush}"
                  CornerRadius="6"
                  Margin="0,0,0,8"
                  Padding="10">
            <StackPanel Spacing="2">
              <TextBlock Text="{Binding Title}" Foreground="{Binding ForegroundBrush}" FontWeight="SemiBold" />
              <TextBlock Text="{Binding Url}" Foreground="{Binding ForegroundBrush}" Opacity="0.92" />
            </StackPanel>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <StackPanel Grid.Row="0" Grid.Column="1" Spacing="8" Width="120">
      <Button x:Name="OpenButton" Content="Open" Click="OpenButton_Click" />
      <Button x:Name="AddButton" Content="Add" Click="AddButton_Click" />
      <Button x:Name="EditButton" Content="Edit" Click="EditButton_Click" />
      <Button x:Name="RemoveButton" Content="Remove" Click="RemoveButton_Click" />
      <Button x:Name="SetDefaultButton" Content="Set default" Click="SetDefaultButton_Click" />
    </StackPanel>

    <StackPanel Grid.Row="1" Grid.ColumnSpan="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8">
      <Button x:Name="CloseButton" Content="Close" IsCancel="True" Click="CloseButton_Click" />
    </StackPanel>
  </Grid>
</Window>
